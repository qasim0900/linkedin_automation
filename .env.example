# LinkedIn Automation System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ===========================================
# LINKEDIN CREDENTIALS (REQUIRED)
# ===========================================
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
MONGO_CONNECTION=mongodb://localhost:27017/
DATABASE_NAME=linkedin_automation

# Collection Names (optional - defaults provided)
PROFILES_COLLECTION=profiles
CONNECTIONS_COLLECTION=connections
MESSAGES_COLLECTION=messages
ACTIVITY_LOG_COLLECTION=activity_log

# ===========================================
# RATE LIMITING CONFIGURATION
# ===========================================
# Daily limits
MAX_CONNECTIONS_PER_DAY=20
MAX_MESSAGES_PER_DAY=15
MAX_PROFILE_VISITS_PER_DAY=50

# ===========================================
# HUMAN BEHAVIOR SETTINGS
# ===========================================
# Delay ranges in seconds
MIN_DELAY_SECONDS=2.0
MAX_DELAY_SECONDS=8.0
MIN_TYPING_DELAY=0.05
MAX_TYPING_DELAY=0.15

# ===========================================
# BROWSER CONFIGURATION
# ===========================================
# Display settings
HEADLESS_MODE=false
WINDOW_WIDTH=1600
WINDOW_HEIGHT=900

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ===========================================
# SESSION MANAGEMENT
# ===========================================
SESSION_TIMEOUT_MINUTES=30
COOKIE_FILE=data/cookies.pkl

# ===========================================
# SCHEDULING CONFIGURATION
# ===========================================
# Working hours (24-hour format)
AUTOMATION_START_HOUR=9
AUTOMATION_END_HOUR=18

# ===========================================
# URL CONFIGURATION (optional - defaults provided)
# ===========================================
LINKEDIN_LOGIN_URL=https://www.linkedin.com/login
GOOGLE_SEARCH_URL=https://www.google.com/search

# ===========================================
# XPATH SELECTORS (optional - defaults provided)
# ===========================================
# Login selectors
EMAIL_INPUT_XPATH=//input[@id='username']
PASSWORD_INPUT_XPATH=//input[@id='password']
LOGIN_BUTTON_XPATH=//button[@type='submit']
LOADING_PAGE_XPATH=//div[contains(@class, 'feed-identity-module')]

# Profile selectors
PROFILE_NAME_XPATH=//h1[@class='text-heading-xlarge']
CONNECT_BUTTON_XPATH=//button[contains(., 'Connect')]
FOLLOW_BUTTON_XPATH=//button[contains(., 'Follow')]
MESSAGE_BUTTON_XPATH=//button[contains(., 'Message')]
MESSAGE_TEXTBOX_XPATH=//div[@contenteditable='true']
SEND_MESSAGE_BUTTON_XPATH=//button[contains(., 'Send')]
SEND_WITHOUT_NOTE_XPATH=//button[contains(., 'Send without a note')]

# Scraping selectors
GOOGLE_PROFILES_XPATH=//div[@class='g']//a[contains(@href, 'linkedin.com/in')]/ancestor::div[@class='g']
GOOGLE_NEXT_LINK_XPATH=//a[@id='pnnext']
CONNECTION_LIST_XPATH=//div[contains(@class, 'mn-connections')]//a[contains(@href, 'linkedin.com/in')]

# ===========================================
# ADVANCED CONFIGURATION
# ===========================================
# Chrome driver version (auto-detected if not specified)
CHROME_DRIVER_VERSION=144

# Proxy settings (optional)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080

# Debug mode
DEBUG_MODE=false

# Performance monitoring
MONITOR_PERFORMANCE=true
